# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# MISTRAL_API_KEY: Required for Mistral AI API calls.
MISTRAL_API_KEY="your_mistral_api_key_here"

# IMAGEKIT_PUBLIC_KEY: Required for ImageKit image uploads.
IMAGEKIT_PUBLIC_KEY="your_imagekit_public_key_here"

# IMAGEKIT_PRIVATE_KEY: Required for ImageKit image uploads.
IMAGEKIT_PRIVATE_KEY="your_imagekit_private_key_here"

# IMAGEKIT_URL_ENDPOINT: Required for ImageKit image uploads.
IMAGEKIT_URL_ENDPOINT="your_imagekit_url_endpoint_here"
