rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    
    function uidUnchanged() {
      return !('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('userId' in request.resource.data) || request.resource.data.userId == resource.data.userId;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.createdAt is timestamp;
    }
    
    function isValidItem(data) {
      return data.keys().hasAll(['userId', 'type', 'title', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.type in ['article', 'video', 'image', 'pdf', 'note', 'social'] &&
             data.title is string && data.title.size() <= 500 &&
             (!('isPublic' in data) || data.isPublic is bool) &&
             data.createdAt is timestamp;
    }
    
    function isValidCollection(data) {
      return data.keys().hasAll(['userId', 'name', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.name is string && data.name.size() <= 100 &&
             (!('description' in data) || data.description is string) &&
             (!('itemIds' in data) || data.itemIds is list) &&
             (!('isPublic' in data) || data.isPublic is bool) &&
             data.createdAt is timestamp;
    }
    
    function isValidRelation(data) {
      return data.keys().hasAll(['userId', 'sourceItemId', 'targetItemId', 'type', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.sourceItemId is string &&
             data.targetItemId is string &&
             data.type in ['similar', 'reference'] &&
             data.createdAt is timestamp;
    }
    
    function isValidHighlight(data) {
      return data.keys().hasAll(['userId', 'itemId', 'text', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.itemId is string &&
             data.text is string && data.text.size() <= 10000 &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && uidUnchanged();
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && uidNotModified();
      allow delete: if isOwner(userId);
    }

    match /items/{itemId} {
      allow read: if isDocOwner() || (resource != null && resource.data.isPublic == true);
      allow create: if isAuthenticated() && isValidItem(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidItem(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /collections/{collectionId} {
      allow read: if isDocOwner() || (resource != null && resource.data.isPublic == true);
      allow create: if isAuthenticated() && isValidCollection(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidCollection(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /relations/{relationId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidRelation(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidRelation(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /highlights/{highlightId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidHighlight(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidHighlight(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }
  }
}
