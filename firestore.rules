rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() &&
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          (request.auth.token.email == "ektak144@gmail.com" && request.auth.token.email_verified == true)
        );
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    
    function uidUnchanged() {
      return !('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('userId' in request.resource.data) || request.resource.data.userId == resource.data.userId;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt']) &&
             data.email is string &&
             data.createdAt is timestamp &&
             (!('role' in data) || data.role in ['admin', 'user']) &&
             (!('permissions' in data) || data.permissions is list) &&
             (!('disabledFeatures' in data) || data.disabledFeatures is list);
    }
    
    function isValidItem(data) {
      return data.keys().hasAll(['userId', 'type', 'title', 'createdAt']) &&
             data.type in ['article', 'video', 'image', 'pdf', 'note', 'social', 'journal'] &&
             data.title is string && data.title.size() <= 500 &&
             (!('isPublic' in data) || data.isPublic is bool) &&
             data.createdAt is timestamp;
    }
    
    function isValidCollection(data) {
      return data.keys().hasAll(['userId', 'name', 'createdAt']) &&
             data.name is string && data.name.size() <= 100 &&
             (!('description' in data) || data.description is string) &&
             (!('itemIds' in data) || data.itemIds is list) &&
             (!('isPublic' in data) || data.isPublic is bool) &&
             data.createdAt is timestamp;
    }
    
    function isValidRelation(data) {
      return data.keys().hasAll(['userId', 'sourceItemId', 'targetItemId', 'type', 'createdAt']) &&
             data.sourceItemId is string &&
             data.targetItemId is string &&
             data.type in ['similar', 'reference'] &&
             data.createdAt is timestamp;
    }
    
    function isValidHighlight(data) {
      return data.keys().hasAll(['userId', 'itemId', 'text', 'createdAt']) &&
             data.itemId is string &&
             data.text is string && data.text.size() <= 10000 &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && (!('role' in request.resource.data) || request.resource.data.role == 'user' || isAdmin());
      allow update: if isValidUser(request.resource.data) && (
        (request.auth.token.email == "ektak144@gmail.com" && request.auth.token.email_verified == true) ||
        (isAdmin() && !isOwner(userId)) ||
        (isOwner(userId) && 
         (!('role' in request.resource.data) || request.resource.data.role == resource.data.role) && 
         (!('permissions' in request.resource.data) || request.resource.data.permissions == resource.data.permissions) &&
         (!('disabledFeatures' in request.resource.data) || request.resource.data.disabledFeatures == resource.data.disabledFeatures))
      );
      allow delete: if (isAdmin() && !isOwner(userId)) || (request.auth.token.email == "ektak144@gmail.com" && request.auth.token.email_verified == true);
    }

    match /items/{itemId} {
      allow read: if isDocOwner() || (resource != null && resource.data.isPublic == true) || isAdmin();
      allow create: if isAuthenticated() && isValidItem(request.resource.data) && uidUnchanged();
      allow update: if (isDocOwner() || isAdmin()) && isValidItem(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /collections/{collectionId} {
      allow read: if isDocOwner() || (resource != null && resource.data.isPublic == true) || isAdmin();
      allow create: if isAuthenticated() && isValidCollection(request.resource.data) && uidUnchanged();
      allow update: if (isDocOwner() || isAdmin()) && isValidCollection(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /relations/{relationId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidRelation(request.resource.data) && uidUnchanged();
      allow update: if (isDocOwner() || isAdmin()) && isValidRelation(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /highlights/{highlightId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidHighlight(request.resource.data) && uidUnchanged();
      allow update: if (isDocOwner() || isAdmin()) && isValidHighlight(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner() || isAdmin();
    }
    
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /analytics/{docId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update: if true; // simplified for prototype
    }
  }
}
