{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the Second Brain application.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID." },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Item": {
      "title": "Item",
      "description": "A saved piece of content (article, video, image, pdf, note).",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["article", "video", "image", "pdf", "note"] },
        "title": { "type": "string" },
        "content": { "type": "string", "description": "Text content or description." },
        "url": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "summary": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "title", "createdAt"]
    },
    "Collection": {
      "title": "Collection",
      "description": "A user-defined grouping of items.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "itemIds": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "createdAt"]
    },
    "Relation": {
      "title": "Relation",
      "description": "A relationship between two items.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "sourceItemId": { "type": "string" },
        "targetItemId": { "type": "string" },
        "type": { "type": "string", "enum": ["similar", "reference"] },
        "weight": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "sourceItemId", "targetItemId", "type", "createdAt"]
    },
    "Highlight": {
      "title": "Highlight",
      "description": "A highlighted text from an item.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "itemId": { "type": "string" },
        "text": { "type": "string" },
        "note": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "itemId", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles."
    },
    "/items/{itemId}": {
      "schema": { "$ref": "#/entities/Item" },
      "description": "Saved content items."
    },
    "/collections/{collectionId}": {
      "schema": { "$ref": "#/entities/Collection" },
      "description": "User collections."
    },
    "/relations/{relationId}": {
      "schema": { "$ref": "#/entities/Relation" },
      "description": "Knowledge graph relations."
    },
    "/highlights/{highlightId}": {
      "schema": { "$ref": "#/entities/Highlight" },
      "description": "Text highlights."
    }
  }
}
